# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_ENV=test
DEBUG=true

# 测试API配置
BASE_URL=https://jsonplaceholder.typicode.com
API_TIMEOUT=30
REQUEST_RETRIES=3

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs

# 报告配置
REPORT_DIR=allure-results
ALLURE_ENABLED=true

# 测试数据配置
TEST_DATA_PATH=tests/data
FAKE_SEED=42

# 认证信息（示例）
# API_KEY=your_api_key_here
# API_SECRET=your_api_secret_here
